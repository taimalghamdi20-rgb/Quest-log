# Discord bot token — from https://discord.com/developers/applications > your app > Bot
BOT_TOKEN=your_bot_token_here

# The channel ID where access requests should be posted (right-click channel > Copy Channel ID)
LOG_CHANNEL_ID=your_channel_id_here

# Optional: only members with this role ID can click Accept/Reject.
# Leave blank to allow anyone in the server to click the buttons.
APPROVER_ROLE_ID=

# Port the API server listens on
PORT=3000
